<Window x:Class="HexMerge.Views.CompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:HexMerge.Views"
        Title="HexMerge" Height="700" Width="1180" MinHeight="480" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasBrush}"
        FontFamily="{DynamicResource UiFont}" FontSize="12.5"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <v:StatusToBrushConverter x:Key="StatusBrush"/>
        <v:StatusToGlyphConverter x:Key="StatusGlyph"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ===== 顶部命令条：真实动作直接可见 ===== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1" Padding="10,7">
            <Grid>
                <!-- 左：重新比较 · 优先级 · 空隙填充 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" Height="32" Click="Recompare_Click" ToolTip="返回文件选择窗，重新选择文件比较">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="重新比较" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{StaticResource HairlineBrush}" Margin="8,0"/>

                    <TextBlock Text="优先级" Foreground="{StaticResource MutedBrush}" FontSize="12.5" VerticalAlignment="Center" Margin="2,0,7,0"/>
                    <ComboBox x:Name="PriorityCombo" Width="240" Height="32" FontSize="12.5" VerticalContentAlignment="Center"
                              ItemsSource="{Binding PriorityOptions}" SelectedIndex="{Binding PrioritySelection, Mode=OneWay}"
                              SelectionChanged="PriorityCombo_SelectionChanged"
                              ToolTip="冲突段的自动仲裁优先级；「无」表示逐段手动确认"/>

                    <TextBlock Text="间隙填充" Foreground="{StaticResource MutedBrush}" FontSize="12.5" VerticalAlignment="Center" Margin="14,0,7,0"/>
                    <ComboBox x:Name="FillCombo" Width="100" Height="32" FontSize="12.5" VerticalContentAlignment="Center"
                              ItemsSource="{Binding FillOptions}" SelectedIndex="{Binding FillSelection, Mode=OneWay}"
                              SelectionChanged="FillCombo_SelectionChanged"
                              ToolTip="同区间隙的填充字节；跨大区/到 DFlash 的间隙不填充"/>
                </StackPanel>

                <!-- 右：检查器开关 · 关于 · 保存 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="InspectorToggle" Style="{StaticResource ToolbarButton}" Height="32" Click="ToggleInspector_Click" ToolTip="显示/隐藏冲突导航">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="冲突导航" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Height="32" Width="34" Padding="0" Click="About_Click" ToolTip="关于 HexMerge">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{StaticResource HairlineBrush}" Margin="8,0"/>
                    <Button Style="{StaticResource PrimaryButton}" Height="32" Command="{Binding MergeCommand}" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="保存 Full.hex" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 底部状态栏：语义字形 + 语义色 ===== -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0" Padding="14,7">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage, Converter={StaticResource StatusGlyph}}"
                           FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,9,0"
                           Foreground="{Binding StatusMessage, Converter={StaticResource StatusBrush}}"/>
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Foreground="{Binding StatusMessage, Converter={StaticResource StatusBrush}}"/>
            </StackPanel>
        </Border>

        <!-- ===== 主区：网格 + 右侧停靠检查器 ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 网格宿主：由 code-behind 填入 [内存地图标尺 | 自绘网格 | 滚动条] -->
            <Grid x:Name="CompareHost" Grid.Column="0" Margin="2,2,0,2"/>

            <!-- 冲突检查器（停靠，可折叠） -->
            <Border x:Name="Inspector" Grid.Column="1" Width="220"
                    Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1" Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource SignalBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="冲突导航" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="14">
                        <!-- 冲突计数卡：当前 / 总数 -->
                        <Border Background="{StaticResource SignalSoftBrush}" BorderBrush="{StaticResource SignalSoftBorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12,9">
                            <StackPanel>
                                <TextBlock Text="冲突段" Style="{StaticResource Eyebrow}"/>
                                <TextBlock Text="{Binding ConflictInfoText}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource SignalBrush}"
                                           Margin="0,3,0,0" TextOptions.TextFormattingMode="Ideal"/>
                                <TextBlock Text="当前 / 总数" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 当前优先级 -->
                        <TextBlock Text="当前优先级" Style="{StaticResource Eyebrow}" Margin="2,16,0,0"/>
                        <TextBlock Text="{Binding CurrentPriorityName}" Foreground="{StaticResource InkBrush}"
                                   FontSize="12.5" TextWrapping="Wrap" Margin="2,3,0,0"/>

                        <!-- 导航 -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="上一个" Height="32" Style="{StaticResource SecondaryButton}" Padding="0" Click="PrevConflict_Click"/>
                            <Button Grid.Column="2" Content="下一个" Height="32" Style="{StaticResource PrimaryButton}" Padding="0" Click="NextConflict_Click"/>
                        </Grid>

                        <!-- 提示 -->
                        <TextBlock Text="在左侧对比区右键某个冲突行，可整段选择保留哪个文件，或恢复为按优先级。"
                                   Foreground="{StaticResource FaintBrush}" FontSize="11" TextWrapping="Wrap" Margin="2,16,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
