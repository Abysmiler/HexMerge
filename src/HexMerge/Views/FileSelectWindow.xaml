<Window x:Class="HexMerge.Views.FileSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HexMerge" Height="600" Width="680" MinHeight="520" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasBrush}"
        FontFamily="{DynamicResource UiFont}" FontSize="12.5"
        AllowDrop="True" PreviewDragOver="Window_DragOver" PreviewDrop="Window_Drop"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="22,20,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 标题 -->
            <RowDefinition Height="Auto"/>  <!-- 装载台 -->
            <RowDefinition Height="*"/>     <!-- 读数 -->
            <RowDefinition Height="Auto"/>  <!-- 底栏 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="2,0,0,16">
            <TextBlock Text="合并固件文件" FontSize="19" FontWeight="SemiBold"
                       Foreground="{StaticResource InkStrongBrush}"/>
            <TextBlock Text="拖入或浏览 2–3 个 HEX / DAT 文件，按地址合并为可烧录的 Full.hex"
                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 装载台：整块可拖放，三个编号槽位 -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,12,14,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="2,0,0,10">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{StaticResource SignalBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="选择文件" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
                    <TextBlock Text="至少 2 个，第 3 个可选" Foreground="{StaticResource FaintBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- 槽 1 -->
                <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="10,9" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13" VerticalAlignment="Top"
                                Background="{StaticResource SignalSoftBrush}" Margin="0,5,12,0">
                            <TextBlock Text="1" FontWeight="SemiBold" Foreground="{StaticResource SignalBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <Grid Height="36">
                                <TextBox x:Name="Path1Box" Text="{Binding Path1, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFont}" Style="{StaticResource InputBox}"
                                         TextChanged="PathBox_TextChanged" ToolTip="{Binding Path1}"/>
                                <TextBlock Text="拖入文件，或点击“浏览”…" Foreground="{StaticResource FaintBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=Path1Box}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,1"
                                        Visibility="{Binding BaseAddrVisible1, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="DAT 基地址" Style="{StaticResource Eyebrow}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBox Text="{Binding BaseAddr1, UpdateSourceTrigger=PropertyChanged}" Width="130" Height="32"
                                         FontFamily="{StaticResource MonoFont}" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                            <Button Content="浏览" Width="76" Height="36" Style="{StaticResource SecondaryButton}" Command="{Binding Browse1Command}"/>
                            <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="34" Height="36" Padding="0"
                                    Margin="6,0,0,0" Style="{StaticResource ToolbarButton}" ToolTip="清除此槽" Click="Clear1_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 槽 2 -->
                <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="10,9" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13" VerticalAlignment="Top"
                                Background="{StaticResource SignalSoftBrush}" Margin="0,5,12,0">
                            <TextBlock Text="2" FontWeight="SemiBold" Foreground="{StaticResource SignalBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <Grid Height="36">
                                <TextBox x:Name="Path2Box" Text="{Binding Path2, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFont}" Style="{StaticResource InputBox}"
                                         TextChanged="PathBox_TextChanged" ToolTip="{Binding Path2}"/>
                                <TextBlock Text="拖入文件，或点击“浏览”…" Foreground="{StaticResource FaintBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=Path2Box}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,1"
                                        Visibility="{Binding BaseAddrVisible2, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="DAT 基地址" Style="{StaticResource Eyebrow}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBox Text="{Binding BaseAddr2, UpdateSourceTrigger=PropertyChanged}" Width="130" Height="32"
                                         FontFamily="{StaticResource MonoFont}" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                            <Button Content="浏览" Width="76" Height="36" Style="{StaticResource SecondaryButton}" Command="{Binding Browse2Command}"/>
                            <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="34" Height="36" Padding="0"
                                    Margin="6,0,0,0" Style="{StaticResource ToolbarButton}" ToolTip="清除此槽" Click="Clear2_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 槽 3（可选） -->
                <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="10,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13" VerticalAlignment="Top"
                                Background="{StaticResource NeutralBrush}" Margin="0,5,12,0">
                            <TextBlock Text="3" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <Grid Height="36">
                                <TextBox x:Name="Path3Box" Text="{Binding Path3, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFont}" Style="{StaticResource InputBox}"
                                         TextChanged="PathBox_TextChanged" ToolTip="{Binding Path3}"/>
                                <TextBlock Text="可选：拖入或点击“浏览”…" Foreground="{StaticResource FaintBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=Path3Box}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,1"
                                        Visibility="{Binding BaseAddrVisible3, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="DAT 基地址" Style="{StaticResource Eyebrow}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBox Text="{Binding BaseAddr3, UpdateSourceTrigger=PropertyChanged}" Width="130" Height="32"
                                         FontFamily="{StaticResource MonoFont}" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                            <Button Content="浏览" Width="76" Height="36" Style="{StaticResource SecondaryButton}" Command="{Binding Browse3Command}"/>
                            <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Width="34" Height="36" Padding="0"
                                    Margin="6,0,0,0" Style="{StaticResource ToolbarButton}" ToolTip="清除此槽" Click="Clear3_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- 读数控制台 -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="0" ClipToBounds="True">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="解析结果" Style="{StaticResource Eyebrow}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Grid>
                    <TextBox Text="{Binding ResultMessage, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Background="{StaticResource SurfaceBrush}"
                             FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource InkBrush}"
                             Padding="14,10" TextOptions.TextFormattingMode="Ideal"/>
                    <TextBlock Text="选择文件并点击“比较”后，这里显示各文件的地址段、大小和冲突数量。"
                               Foreground="{StaticResource FaintBrush}" FontSize="12" TextWrapping="Wrap"
                               VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15,11,15,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResultMessage}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

        <!-- 底栏：状态 + 动作 -->
        <Grid Grid.Row="3" Margin="2,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{StaticResource SignalBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="92" Height="36" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Click="Cancel_Click"/>
                <Button Content="比较" Width="116" Height="36" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CompareCommand}" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
